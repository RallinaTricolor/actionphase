{
  "skills": {
    "backend-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Comprehensive backend development guide for Go/Chi/PostgreSQL with Clean Architecture patterns, sqlc database access, interface-first development, and service decomposition",
      "promptTriggers": {
        "keywords": [
          "backend",
          "Go service",
          "Chi router",
          "Chi middleware",
          "sqlc",
          "database migration",
          "API handler",
          "API endpoint",
          "middleware",
          "JWT auth",
          "JWT authentication",
          "PostgreSQL",
          "service layer",
          "repository pattern",
          "HTTP handler",
          "REST API",
          "correlation ID",
          "structured logging",
          "service interface",
          "interfaces.go",
          "Clean Architecture",
          "service decomposition",
          "layered architecture",
          "pgxpool",
          "error handling",
          "input validation",
          "zerolog"
        ],
        "intentPatterns": [
          "(create|add|implement|write|build).*?(handler|endpoint|API|service|migration|middleware|interface)",
          "(fix|debug|troubleshoot|resolve).*?(backend|Go|database|API)",
          "(add|implement|setup|configure).*?(middleware|auth|validation|logging|interface)",
          "(refactor|improve|optimize|decompose).*?(service|handler|query|backend)",
          "(define|create).*?interface",
          "interface.*?first"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "backend/pkg/**/*.go",
          "backend/cmd/**/*.go",
          "backend/pkg/db/queries/**/*.sql",
          "backend/pkg/db/migrations/**/*.sql"
        ],
        "pathExclusions": [
          "**/*_test.go",
          "**/*.pb.go"
        ],
        "contentPatterns": [
          "chi\\.NewRouter",
          "http\\.Handler",
          "func.*\\(w http\\.ResponseWriter",
          "type.*Service.*interface",
          "type.*Interface interface",
          "sqlc",
          "-- name:",
          "errors\\.Wrap",
          "pgxpool\\.Pool",
          "zerolog",
          "middleware\\.GetCorrelationID"
        ]
      }
    },
    "frontend-dev-guidelines": {
      "type": "guardrail",
      "enforcement": "warn",
      "priority": "high",
      "description": "React/TypeScript patterns with React Query and Tailwind CSS",
      "promptTriggers": {
        "keywords": [
          "component",
          "React component",
          "UI component",
          "React Query",
          "useQuery",
          "useMutation",
          "Tailwind CSS",
          "dark mode",
          "AuthContext",
          "React hook",
          "custom hook",
          "frontend state",
          "Vite",
          "TypeScript interface",
          "props",
          "React Router"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(component|hook|page|UI|frontend)",
          "(fix|debug|troubleshoot).*?(React|frontend|component|UI)",
          "(style|theme|design).*?(component|page|UI)",
          "(add|implement).*?(state|context|hook|query)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "frontend/src/**/*.tsx",
          "frontend/src/**/*.ts",
          "frontend/src/**/*.css"
        ],
        "pathExclusions": [
          "**/*.test.tsx",
          "**/*.test.ts",
          "**/*.spec.ts",
          "**/node_modules/**"
        ],
        "contentPatterns": [
          "import.*React",
          "export.*function.*Component",
          "export.*const.*Component",
          "useQuery",
          "useMutation",
          "useState",
          "useEffect",
          "tailwind"
        ]
      }
    },
