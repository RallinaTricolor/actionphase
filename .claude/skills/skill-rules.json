          "frontend state",
          "Vite",
          "TypeScript interface",
          "props",
          "React Router"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(component|hook|page|UI|frontend)",
          "(fix|debug|troubleshoot).*?(React|frontend|component|UI)",
          "(style|theme|design).*?(component|page|UI)",
          "(add|implement).*?(state|context|hook|query)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "frontend/src/**/*.tsx",
          "frontend/src/**/*.ts",
          "frontend/src/**/*.css"
        ],
        "pathExclusions": [
          "**/*.test.tsx",
          "**/*.test.ts",
          "**/*.spec.ts",
